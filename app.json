{
  "expo": {
    "name": "HQ Kids",
    "slug": "hq-kids",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "hq-kids",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF9F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hqkids.app",
      "infoPlist": {
        "NSCameraUsageDescription": "HQ Kids precisa da câmera para comprovar tarefas concluídas",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF9F0"
      },
      "package": "com.hqkids.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "HQ Kids precisa da câmera para comprovar tarefas concluídas"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "HQ Kids precisa acessar suas fotos"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0177b4d-9168-4dcb-86cd-3a19638a23f8"
      }
    },
    "owner": "johnmagnavita"
  }
}
